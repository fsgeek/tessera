#!/bin/bash
# Post-commit OpenTimestamps hook (the WHEN layer).
#
# After every non-ots commit, write the commit hash to timestamps/<hash>,
# stamp it with OpenTimestamps (anchors to Bitcoin via calendar servers),
# then commit the .ots proof. This makes the commit's existence-time
# non-backdatable — the core of the pre-registration credibility claim.
#
# Design note vs. the original governance-project hook: that version did a
# SILENT skip (exit 0) when the ots client was missing, which is governance
# theater — you'd believe commits were anchored when they weren't. This
# version resolves ots robustly (uv run, then local .venv) and FAILS LOUDLY
# if it genuinely cannot stamp. A missing stamp must be visible, not silent.
set -e

GIT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_ROOT"

# Guard: never stamp the ots-bookkeeping commits themselves (they are created
# below with --no-verify, which skips pre-commit but NOT post-commit).
COMMIT_MSG=$(git log -1 --format="%s")
if [[ "$COMMIT_MSG" == ots:* ]]; then
    exit 0
fi

# Resolve the ots client. Prefer the project venv directly (fast, no uv
# resolution overhead); fall back to `uv run ots` (location-independent).
if [ -x "$GIT_ROOT/.venv/bin/ots" ]; then
    OTS=("$GIT_ROOT/.venv/bin/ots")
elif command -v uv >/dev/null 2>&1 && uv run --quiet ots --version >/dev/null 2>&1; then
    OTS=(uv run --quiet ots)
else
    echo "FATAL: ots client not found (.venv/bin/ots absent and 'uv run ots' failed)." >&2
    echo "       Commit $(git rev-parse --short HEAD) is NOT timestamped." >&2
    echo "       Run: uv sync   then   scripts/install-hooks.sh" >&2
    exit 1
fi

HASH=$(git rev-parse HEAD)
TIMESTAMP_DIR="$GIT_ROOT/timestamps"
mkdir -p "$TIMESTAMP_DIR"

HASH_FILE="$TIMESTAMP_DIR/$HASH"
echo "$HASH" > "$HASH_FILE"

if ! "${OTS[@]}" stamp "$HASH_FILE"; then
    echo "FATAL: 'ots stamp' failed for $HASH — commit is NOT timestamped." >&2
    rm -f "$HASH_FILE"
    exit 1
fi

git add "$TIMESTAMP_DIR/"
git commit --no-verify -m "ots: stamp $HASH"
